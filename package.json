{
  "name": "@ragenet/openclaw-webdav",
  "version": "0.1.5",
  "description": "WebDAV plugin for OpenClaw",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "openclaw": {
    "extensions": ["./dist/index.js"]
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:conformance": "tsx .conformance/run-litmus.ts",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "webdav",
    "openclaw",
    "plugin"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RageDotNet/openclaw-webdav.git"
  },
  "bugs": {
    "url": "https://github.com/RageDotNet/openclaw-webdav/issues"
  },
  "homepage": "https://github.com/RageDotNet/openclaw-webdav#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "packageManager": "pnpm@10.32.0",
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.9",
    "mime-types": "^3.0.2",
    "xmlbuilder2": "^4.0.3"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.28"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  }
}
